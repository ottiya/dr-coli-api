      "bori": { "animation": "look" },
      "interaction": { "type": "mic_optional" }
    },

    {
      "id": "meet-bori",
      "drColi": {
        "say": [
          "And this is my friend Bori.",
          "Bori is a puppy."
        ],
        "animation": "idle"
      },
      "bori": { "animation": "wave" },
      "interaction": {
        "type": "emoji",
